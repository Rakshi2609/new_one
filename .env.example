# Gemini 1.5 Flash API Key (required for AI extraction and coaching)
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB URI (optional — falls back to in-memory if not set)
MONGO_URI=mongodb://localhost:27017

# Mistral AI Key (optional — used for legacy plan/coach fallback)
MISTRAL_API_KEY=your_mistral_api_key_here

# ElevenLabs Key (optional — used for audio transcription fallback)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# JWT Secret (customize for production)
JWT_SECRET=change-this-to-a-strong-random-secret

# Vault encryption key (auto-generated if not set)
# VAULT_KEY=base64_urlsafe_fernet_key_here
